# BUILD.CV Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# AI Configuration
# Supported providers: openai, gemini, grok
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-your-openai-key-here
GEMINI_API_KEY=your-gemini-api-key
GROK_API_KEY=xai-your-grok-api-key

# Application Environment
APP_ENV=development
DEBUG=false

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=build_cv

# Application Settings
APP_NAME=BUILD.CV
APP_URL=http://localhost/BUILD.CV
APP_VERSION=1.0.0

# Session Settings (in seconds)
SESSION_LIFETIME=2592000

# File Upload Settings (in bytes)
MAX_FILE_SIZE=5242880

# Pagination
ITEMS_PER_PAGE=10
